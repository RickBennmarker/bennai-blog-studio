# De koppelingen (OpenRouter-sleutel, CMS-credentials, siteprofiel) vul je in
# via de setup-wizard in de app zelf — ze worden per gebruiker opgeslagen in
# data/settings.json. Deze .env is optioneel.

# Optioneel: gedeelde OpenRouter-sleutel als terugval wanneer een gebruiker er
# in de wizard geen invult. https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Optioneel: DataForSEO voor echte zoekvolumes en keyword difficulty op de
# Kansen-pagina. Zonder deze twee draait de analyse op alleen Google autocomplete.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Zelfgekozen geheim waarmee de autopilot cron-route beveiligd is
CRON_SECRET=verzin-hier-een-lang-geheim

# Basis-URL van het dashboard (voor de lokale scheduler)
APP_URL=http://localhost:3000
